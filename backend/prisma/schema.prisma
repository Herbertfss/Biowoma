generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlantIdentification {
  id           String   @id @default(uuid())
  name         String
  description  String
  imageUrl     String
  identifiedBy String
  createdAt    DateTime @default(now())
}
